[Unit]
Description=Booster K1 MJPEG Camera Server
After=network.target booster-daemon-perception.service
Wants=booster-daemon-perception.service
StartLimitInterval=60
StartLimitBurst=5

[Service]
Type=simple
User=booster
Environment="PYTHONUNBUFFERED=1"
ExecStartPre=/bin/sleep 5
ExecStart=/bin/bash -c 'source /opt/ros/humble/setup.bash && exec python3 /home/booster/camera_server/camera_server.py'
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
